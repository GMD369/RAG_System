# Required: API key for Grok (xAI) or Groq
# Groq keys start with gsk_ — defaults to llama-3.3-70b-versatile
# xAI keys — model is auto-selected from your available models
GROK_API_KEY=

# Optional: override auto-selected model (e.g. grok-2-1212)
GROK_MODEL=

# Optional: override API base URL
GROK_BASE_URL=

# Optional: HuggingFace embedding model (default: all-MiniLM-L6-v2)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: retrieval settings
RETRIEVAL_SCORE_THRESHOLD=0.3
RETRIEVAL_TOP_K=5
